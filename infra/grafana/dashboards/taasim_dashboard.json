  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "hadesarchitect-cassandra-datasource",
        "uid": "PE3297E400DFF12FE"
      },
      "target": "SELECT latitude as lat, longitude as lon, taxi_id, status FROM vehicle_positions LIMIT 1000",
      "rawQuery": true,
      "queryType": "query"
