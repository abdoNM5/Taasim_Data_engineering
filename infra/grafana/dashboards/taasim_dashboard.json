      "lon": -7.6,
      "zoom": 12
    },
    "layers": [
      {
        "type": "markers",
        "name": "Vehicles",
        "config": {
          "style": {
            "color": { "fixed": "green" },
            "size": { "fixed": 6 },
            "symbol": { "fixed": "img/icons/marker/circle.svg" }
          }
        }
      }
    ],
    "tooltip": { "mode": "details" }
  },
  "fieldConfig": {
    "defaults": {},
    "overrides": [
      {
        "matcher": { "id": "byName", "options": "lat" },
